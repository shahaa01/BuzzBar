# App
NODE_ENV=development
PORT=3000

# Admin JWT (set strong values for any shared/staging/prod env)
ADMIN_JWT_ACCESS_SECRET=change_me_access_secret
ADMIN_JWT_REFRESH_SECRET=change_me_refresh_secret
ADMIN_ACCESS_TOKEN_TTL_MIN=15
ADMIN_REFRESH_TOKEN_TTL_DAYS=30

# User JWT (customer auth)
USER_JWT_ACCESS_SECRET=change_me_user_access_secret
USER_JWT_REFRESH_SECRET=change_me_user_refresh_secret
USER_ACCESS_TOKEN_TTL_MIN=15
USER_REFRESH_TOKEN_TTL_DAYS=30

# OAuth provider verification (required to enable real Google/Apple verification in non-test envs)
# GOOGLE_OAUTH_CLIENT_IDS=your-google-client-id-1,your-google-client-id-2
# APPLE_CLIENT_IDS=your-apple-client-id-1,your-apple-client-id-2
# OAUTH_MODE=real

# SuperAdmin bootstrap (used only if no SuperAdmin exists in DB)
SUPERADMIN_BOOTSTRAP_EMAIL=
SUPERADMIN_BOOTSTRAP_PASSWORD=
SUPERADMIN_BOOTSTRAP_NAME=

# Mongo
MONGO_URI=mongodb://localhost:27017/buzzbar

# Cloudinary (required for non-test startup; used by P1.3 uploads + P1.4 KYC)
# Option A:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Option B:
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# KYC (P1.4)
# KYC_CONFIDENCE_THRESHOLD=
# KYC_DOB_TOLERANCE_DAYS=
# KYC_OCR_MODE=
# KYC_OCR_LANGS=eng+nep
# KYC_OCR_PSM=6
# KYC_OCR_TIMEOUT_MS=5000

# Payments ops (P1.8)
# WALLET_PENDING_TIMEOUT_MIN=

# CORS (comma-separated). In development, localhost origins are allowed by default if empty.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
